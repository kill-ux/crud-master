							"script": {
								"exec": [
									"",
									"// Test for POST /api/movies",
									"pm.test(\"Status code is 201 for successful creation\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Response has success message or created movie\", function () {",
									"    const responseData = pm.response.json();",
									"    pm.expect(responseData).to.have.property('message').or.have.property('id');",
									"});",
									"",
									"pm.test(\"Movie can be retrieved after creation\", function () {",
									"    const responseData = pm.response.json();",
									"    if (responseData.id) {",
									"        pm.environment.set(\"last_movie_id\", responseData.id);",
									"    }",
									"});",
									"",
									"// Request body validation tests",
									"pm.test(\"Request body contains required fields\", function () {",
									"    const reqBody = pm.request.body.raw ? JSON.parse(pm.request.body.raw) : {};",
									"    pm.expect(reqBody).to.have.property('title');",
									"    pm.expect(reqBody).to.have.property('description');",
									"    pm.expect(reqBody.title).to.be.a('string').and.not.be.empty;",
									"    pm.expect(reqBody.description).to.be.a('string');",
									"});",
									"",
									"// Error case tests",
									"pm.test(\"Invalid data returns 400\", function () {",
									"    // For invalid request scenarios",
									"    if (pm.response.code === 400) {",
									"        const errorResponse = pm.response.json();",
									"        pm.expect(errorResponse).to.have.property('error');",
									"    }",
									"});"
								],
