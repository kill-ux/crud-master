									"pm.test(\"Status code is 200\", () => pm.response.to.have.status(200));",
									"pm.test(\"ID matches request\", () => {",
									"    pm.expect(pm.response.json().id).to.eql(parseInt(pm.collectionVariables.get(\"last_movie_id\")));",
									"});",
									"",
									"// Test for GET /api/movies/{id}",
									"pm.test(\"Status code is 200 for valid ID\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response is an object\", function () {",
									"    const responseData = pm.response.json();",
									"    pm.expect(responseData).to.be.an('object');",
									"});",
									"",
									"pm.test(\"Movie has all required fields\", function () {",
									"    const movie = pm.response.json();",
									"    pm.expect(movie).to.have.all.keys('id', 'title', 'description');",
									"    pm.expect(movie.id).to.be.a('number');",
									"    pm.expect(movie.title).to.be.a('string');",
									"    pm.expect(movie.description).to.be.a('string');",
									"});",
									"",
									"pm.test(\"Movie ID matches requested ID\", function () {",
									"    const movie = pm.response.json();",
									"    const requestedId = parseInt(pm.collectionVariables.get(\"last_movie_id\"))",
									"    pm.expect(movie.id).to.equal(requestedId);",
									"});",
									"",
									"// Test for error cases (404)",
									"pm.test(\"Non-existent ID returns 404\", function () {",
									"    // This would be a separate request",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
