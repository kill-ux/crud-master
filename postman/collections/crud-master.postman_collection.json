				{
					"name": "update a single movie by id.",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Test for PUT /api/movies/{id} - Verify response matches request",
									"",
									"pm.test(\"Status code is 200 for successful update\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response returns the updated movie with same fields as request\", function () {",
									"    // Get the request body",
									"    const reqBody = JSON.parse(pm.request.body.raw);",
									"    ",
									"    // Get the response body",
									"    const resBody = pm.response.json();",
									"    ",
									"    // Check if response contains the updated movie",
									"    const updatedMovie = resBody.movie || resBody.data || resBody;",
									"    ",
									"    // Verify each field from request matches response",
									"    if (reqBody.title) {",
									"        pm.expect(updatedMovie.title).to.equal(reqBody.title);",
									"    }",
									"    ",
									"    if (reqBody.description) {",
									"        pm.expect(updatedMovie.description).to.equal(reqBody.description);",
									"    }",
									"    ",
									"    // Verify response has all required movie fields",
									"    pm.expect(updatedMovie).to.have.property('id');",
									"    pm.expect(updatedMovie).to.have.property('title');",
									"    pm.expect(updatedMovie).to.have.property('description');",
									"});",
									"",
									"pm.test(\"Only specified fields are updated\", function () {",
									"    const reqBody = JSON.parse(pm.request.body.raw);",
									"    const resBody = pm.response.json();",
									"    const updatedMovie = resBody.movie || resBody.data || resBody;",
									"    ",
									"    // If only title was in request, description should remain unchanged",
									"    // Note: You'd need to know the original values for this test",
									"    if (reqBody.title && !reqBody.description) {",
									"        pm.expect(updatedMovie.title).to.equal(reqBody.title);",
									"        // Description should still exist (unchanged)",
									"        pm.expect(updatedMovie.description).to.be.a('string');",
									"    }",
									"    ",
									"    if (!reqBody.title && reqBody.description) {",
									"        pm.expect(updatedMovie.description).to.equal(reqBody.description);",
									"        pm.expect(updatedMovie.title).to.be.a('string');",
									"    }",
									"});"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
